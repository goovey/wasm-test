{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "Remote Qt WASM Debug",
            "url": "http://localhost:3100/WasmTest.html",
            "webRoot": "${workspaceFolder}",
            "preLaunchTask": "Start Web Server",
            "sourceMaps": true,
            "sourceMapPathOverrides": {
                "wasm://wasm/*": "${workspaceFolder}/*"
            },
            "userDataDir": "${workspaceFolder}/.vscode/chrome-debug-profile",
        }
    ]
}